@model ErrorViewModel
@{
    ViewData["Title"] = "Lỗi";
}

<div class="row justify-content-center py-5">
    <div class="col-md-8 col-lg-6 text-center">
        <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-danger bg-opacity-10 text-danger mb-4" style="width:80px;height:80px;">
            <i class="bi bi-exclamation-triangle fs-1"></i>
        </div>
        <h1 class="h3 fw-bold mb-2">Đã xảy ra lỗi</h1>
        <p class="text-secondary mb-4">Ứng dụng không thể xử lý yêu cầu. Vui lòng thử lại sau hoặc quay về trang chủ.</p>
        @if (Model.ShowRequestId)
        {
            <div class="card card-shop text-start mb-4">
                <div class="card-body py-3">
                    <small class="text-muted text-uppercase fw-semibold d-block mb-1" style="letter-spacing:.06em">Request ID</small>
                    <code class="small">@Model.RequestId</code>
                </div>
            </div>
        }
        <a asp-controller="Home" asp-action="Index" class="btn btn-shop-primary"><i class="bi bi-house me-2"></i>Về trang chủ</a>
    </div>
</div>

<div class="card card-shop mt-4">
    <div class="card-body p-4">
        <h2 class="h6 fw-bold text-muted text-uppercase mb-3" style="letter-spacing:.06em">Chế độ Development</h2>
        <p class="small text-secondary mb-2">
            Bật môi trường <strong>Development</strong> để xem chi tiết lỗi khi gỡ lỗi cục bộ. Không bật trên môi trường triển khai.
        </p>
        <p class="small text-secondary mb-0">
            Đặt biến môi trường <strong>ASPNETCORE_ENVIRONMENT</strong> = <strong>Development</strong> rồi khởi động lại ứng dụng.
        </p>
    </div>
</div>
