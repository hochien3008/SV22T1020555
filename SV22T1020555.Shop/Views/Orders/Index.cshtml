@model PagedResult<OrderSearchInfo>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
    static string StatusPillClass(OrderStatusEnum s) => s switch
    {
        OrderStatusEnum.New => "status-pill status-pill--new",
        OrderStatusEnum.Accepted => "status-pill status-pill--accepted",
        OrderStatusEnum.Shipping => "status-pill status-pill--shipping",
        OrderStatusEnum.Completed => "status-pill status-pill--completed",
        OrderStatusEnum.Cancelled => "status-pill status-pill--cancelled",
        OrderStatusEnum.Rejected => "status-pill status-pill--rejected",
        _ => "status-pill"
    };
}

<div class="shop-back-nav">
    <a asp-controller="Account" asp-action="Profile" class="shop-back-link shop-back-link--smart"><i class="bi bi-arrow-left"></i><span>Quay lại</span></a>
</div>
<div class="shop-page-header">
    <h1 class="h1-line">Lịch sử mua hàng</h1>
    <p class="lead-sub mb-0">Theo dõi trạng thái xử lý và xem chi tiết từng đơn.</p>
</div>

@if (Model.DataItems.Count == 0)
{
    <div class="shop-empty card card-shop p-4 p-lg-5 text-center">
        <div class="display-6 mb-2"><i class="bi bi-receipt"></i></div>
        <div class="fw-bold mb-1">Chưa có đơn hàng nào</div>
        <div class="text-secondary">Khi bạn đặt mua, đơn hàng sẽ xuất hiện ở đây để theo dõi trạng thái.</div>
        <div class="mt-3">
            <a asp-controller="Products" asp-action="Index" class="btn btn-shop-primary btn-lg px-4">Mua sắm ngay</a>
        </div>
    </div>
}
else
{
    <div class="order-list">
        @foreach (var o in Model.DataItems)
        {
            <article class="order-card">
                <div class="order-card__main">
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <div class="order-code">#@o.OrderID</div>
                        <span class="@StatusPillClass(o.Status)">@o.Status.GetDescription()</span>
                    </div>
                    <div class="order-meta mt-2">
                        <span><i class="bi bi-clock me-1"></i>@o.OrderTime.ToString("dd/MM/yyyy HH:mm")</span>
                        <span class="order-meta__dot">•</span>
                        <span><i class="bi bi-cash-coin me-1"></i>Tổng: <strong>@o.SumOfPrice.ToString("N0") đ</strong></span>
                    </div>
                </div>
                <div class="order-card__actions">
                    <a class="btn btn-outline-primary rounded-pill px-3" asp-action="Details" asp-route-id="@o.OrderID">
                        Xem chi tiết <i class="bi bi-chevron-right ms-1"></i>
                    </a>
                </div>
            </article>
        }
    </div>
}
@{
    var pages = Model.PageSize > 0 ? (int)Math.Ceiling(Model.RowCount / (double)Model.PageSize) : 1;
}
@if (pages > 1)
{
    <nav class="mt-4" aria-label="Phân trang">
        <ul class="pagination justify-content-center flex-wrap mb-0">
            @for (var i = 1; i <= pages; i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                </li>
            }
        </ul>
    </nav>
}
