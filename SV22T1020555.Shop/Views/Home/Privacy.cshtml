@{
    ViewData["Title"] = "Chính sách bảo mật";
}

<div class="shop-back-nav">
    <a asp-controller="Home" asp-action="Index" class="shop-back-link shop-back-link--smart"><i class="bi bi-arrow-left"></i><span>Quay lại</span></a>
</div>
<div class="shop-page-header">
    <h1 class="h1-line">@ViewData["Title"]</h1>
    <p class="lead-sub mb-0">Cam kết bảo vệ dữ liệu cá nhân của khách hàng SV Shop.</p>
</div>

<div class="card card-shop">
    <div class="card-body p-4 p-lg-5">
        <p class="mb-4">Trang này mô tả cách chúng tôi thu thập, sử dụng và lưu trữ thông tin khi bạn sử dụng website. Bạn có thể chỉnh sửa nội dung theo quy định thực tế của doanh nghiệp.</p>
        <h2 class="h5 fw-bold mb-3">Dữ liệu thu thập</h2>
        <p class="text-secondary mb-4">Thông tin đăng ký tài khoản, liên hệ và đơn hàng phục vụ xử lý giao dịch và hỗ trợ khách hàng.</p>
        <h2 class="h5 fw-bold mb-3">Liên hệ</h2>
        <p class="text-secondary mb-0">Mọi thắc mắc về quyền riêng tư, vui lòng liên hệ bộ phận chăm sóc khách hàng.</p>
    </div>
</div>
