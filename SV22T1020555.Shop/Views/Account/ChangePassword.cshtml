@model ChangePasswordShopViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="shop-auth-shell">
    <div class="shop-back-nav shop-back-nav--auth text-center text-lg-start">
        <a asp-action="Profile" class="shop-back-link shop-back-link--smart"><i class="bi bi-arrow-left"></i><span>Quay lại</span></a>
    </div>
    <div class="row justify-content-center py-lg-1">
        <div class="col-md-8 col-lg-6 col-xl-5">
            <div class="auth-panel-intro text-center mb-4">
                <div class="auth-icon-stack mb-3 mx-auto">
                    <i class="bi bi-shield-lock"></i>
                </div>
                <p class="auth-panel-kicker mb-0"><i class="bi bi-key-fill"></i> Bảo mật</p>
                <h1 class="auth-panel-title">Đổi mật khẩu</h1>
                <p class="auth-panel-lead mx-auto">Nhập mật khẩu hiện tại và mật khẩu mới để bảo vệ tài khoản.</p>
            </div>
            <div class="card auth-card-accent card-shop">
                <div class="card-body">
                    <form asp-action="ChangePassword" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
                        <div class="mb-3 auth-field">
                            <label asp-for="OldPassword" class="form-label fw-semibold small"></label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text text-muted"><i class="bi bi-key"></i></span>
                                <input asp-for="OldPassword" class="form-control" autocomplete="current-password" />
                            </div>
                            <span asp-validation-for="OldPassword" class="text-danger small"></span>
                        </div>
                        <div class="mb-3 auth-field">
                            <label asp-for="NewPassword" class="form-label fw-semibold small"></label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text text-muted"><i class="bi bi-lock"></i></span>
                                <input asp-for="NewPassword" class="form-control" autocomplete="new-password" />
                            </div>
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>
                        <div class="mb-4 auth-field">
                            <label asp-for="ConfirmPassword" class="form-label fw-semibold small"></label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text text-muted"><i class="bi bi-lock-fill"></i></span>
                                <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-shop-primary btn-lg w-100 py-2 fw-bold rounded-3">Cập nhật mật khẩu</button>
                        <div class="text-center mt-4">
                            <a asp-action="Profile" class="small auth-footer-link text-decoration-none fw-bold shop-back-link--smart"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
