@model CheckoutViewModel
@{
    ViewData["Title"] = "Đặt mua";
    var provinces = ViewBag.Provinces as List<Province> ?? new();
    var cart = ViewBag.CheckoutCart as List<OrderDetailViewInfo> ?? new();
    var checkoutSource = ViewBag.CheckoutSource as string ?? "";
    decimal total = cart.Sum(x => x.Quantity * x.SalePrice);
}

<div class="shop-back-nav">
    <a asp-controller="Cart" asp-action="Index" class="shop-back-link shop-back-link--smart"><i class="bi bi-arrow-left"></i><span>Quay lại</span></a>
</div>
<div class="shop-page-header">
    <nav class="breadcrumb-shop">
        <a asp-controller="Cart" asp-action="Index">Giỏ hàng</a>
        <span class="text-muted"> / </span>
        <span class="text-dark">Đặt mua</span>
    </nav>
    <h1 class="h1-line">Xác nhận đặt hàng</h1>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card card-shop h-100">
            <div class="card-header">
                <i class="bi bi-geo-alt me-2 text-primary"></i>Thông tin giao hàng
            </div>
            <div class="card-body">
                <form asp-action="Index" method="post">
                    <input type="hidden" name="source" value="@checkoutSource" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
                    <div class="mb-3">
                        <label asp-for="DeliveryProvince" class="form-label fw-semibold small"></label>
                        <select asp-for="DeliveryProvince" class="form-select form-select-lg">
                            <option value="">Chọn tỉnh / thành phố</option>
                            @foreach (var p in provinces)
                            {
                                <option value="@p.ProvinceName">@p.ProvinceName</option>
                            }
                        </select>
                        <span asp-validation-for="DeliveryProvince" class="text-danger small d-block"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="DeliveryPhone" class="form-label fw-semibold small"></label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-white text-muted"><i class="bi bi-telephone"></i></span>
                            <input asp-for="DeliveryPhone" class="form-control" placeholder="Số gọi khi giao hàng" autocomplete="tel" />
                        </div>
                        <span asp-validation-for="DeliveryPhone" class="text-danger small d-block"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="DeliveryAddress" class="form-label fw-semibold small"></label>
                        <textarea asp-for="DeliveryAddress" class="form-control" rows="4" placeholder="Số nhà, tên đường, phường/xã, ghi chú (tầng, mã cổng…)"></textarea>
                        <span asp-validation-for="DeliveryAddress" class="text-danger small d-block"></span>
                    </div>
                    <button type="submit" class="btn btn-shop-success btn-lg px-4">
                        <i class="bi bi-check2-circle me-2"></i>Hoàn tất đặt hàng
                    </button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card card-shop position-sticky" style="top: 1rem;">
            <div class="card-header">
                <i class="bi bi-bag-check me-2 text-primary"></i>Đơn hàng (@cart.Count sản phẩm)
            </div>
            <ul class="list-group list-group-flush">
                @foreach (var l in cart)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-start py-3">
                        <div>
                            <div class="fw-medium">@l.ProductName</div>
                            <small class="text-muted">× @l.Quantity</small>
                        </div>
                        <span class="fw-semibold">@((l.Quantity * l.SalePrice).ToString("N0")) đ</span>
                    </li>
                }
            </ul>
            <div class="card-body border-top bg-light">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-bold">Tổng thanh toán</span>
                    <span class="price-tag fs-4">@total.ToString("N0") đ</span>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
