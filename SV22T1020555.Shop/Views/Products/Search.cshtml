@model PagedResult<Product>
@{
    Layout = null;
    var s = ViewBag.Search as ProductSearchInput ?? new ProductSearchInput();
}

@if (Model.DataItems.Count == 0)
{
    <div class="card card-shop shop-empty shop-empty--cart py-5">
        <i class="bi bi-inbox d-block mb-3"></i>
        <p class="mb-2 fs-5 fw-semibold text-dark">Không có mặt hàng phù hợp</p>
        <p class="text-secondary mb-4 small">Thử bỏ bớt bộ lọc hoặc đổi từ khóa.</p>
        <a class="btn btn-shop-primary" href="javascript:;" onclick="resetSearch()"><i class="bi bi-arrow-counterclockwise me-2"></i>Xóa bộ lọc</a>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var p in Model.DataItems)
        {
            <div class="col-6 col-md-4 col-lg-3 col-xxl-2">
                <article class="card product-card product-card--market h-100">
                    <a asp-action="Details" asp-route-id="@p.ProductID" class="product-img-wrap text-center">
                        <span class="product-badge"><i class="bi bi-lightning-charge-fill"></i>Hot</span>
                        <img src="~/images/products/@ProductImage.FileName(p.Photo)" alt="@p.ProductName" />
                    </a>
                    <div class="card-body d-flex flex-column">
                        <a asp-action="Details" asp-route-id="@p.ProductID" class="product-title stretched-link">@p.ProductName</a>
                        <div class="product-meta-row">
                            <p class="price-tag mb-0">
                                @p.Price.ToString("N0") đ
                                <span class="unit">/ @p.Unit</span>
                            </p>
                        </div>
                        <div class="product-meta-row">
                            <span class="product-rating" title="Đánh giá">
                                <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-half"></i>
                            </span>
                            <span class="product-sold">Đã bán 1k+</span>
                        </div>
                    </div>
                </article>
            </div>
        }
    </div>
}

@{
    var totalPages = Model.PageSize > 0 ? (int)Math.Ceiling(Model.RowCount / (double)Model.PageSize) : 1;
    var cur = Model.Page;
    var start = Math.Max(1, cur - 4);
    var end = Math.Min(totalPages, cur + 5);
    if (cur <= 3)
    {
        start = 1;
        end = Math.Min(totalPages, 5 + (cur - 1));
    }
    if (cur >= totalPages - 2)
    {
        end = totalPages;
        start = Math.Max(1, totalPages - 6); 
    }
}
@if (totalPages > 1)
{
    <nav class="mt-5 pt-2" aria-label="Phân trang">
        <ul class="pagination justify-content-center flex-wrap mb-0">
            <li class="page-item @(cur <= 1 ? "disabled" : "")">
                <a class="page-link" href="javascript:;" onclick="doSearch(@(cur - 1))" aria-label="Trang trước">
                    <span aria-hidden="true">&laquo;</span>
                </a>
            </li>

            @if (start > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="javascript:;" onclick="doSearch(1)">1</a>
                </li>
            }
            @if (start > 2)
            {
                <li class="page-item disabled"><span class="page-link">…</span></li>
            }

            @for (var i = start; i <= end; i++)
            {
                <li class="page-item @(i == cur ? "active" : "")">
                    <a class="page-link" href="javascript:;" onclick="doSearch(@i)">@i</a>
                </li>
            }

            @if (end < totalPages - 1)
            {
                <li class="page-item disabled"><span class="page-link">…</span></li>
            }
            @if (end < totalPages)
            {
                <li class="page-item">
                    <a class="page-link" href="javascript:;" onclick="doSearch(@totalPages)">@totalPages</a>
                </li>
            }

            <li class="page-item @(cur >= totalPages ? "disabled" : "")">
                <a class="page-link" href="javascript:;" onclick="doSearch(@(cur + 1))" aria-label="Trang sau">
                    <span aria-hidden="true">&raquo;</span>
                </a>
            </li>
        </ul>
    </nav>
}
